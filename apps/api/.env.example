# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/bsma"

# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL="http://localhost:3000"

# ── Auth ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-value"
JWT_EXPIRES_IN="2h"
# true in production (requires HTTPS) — cookie won't be set by browsers over
# plain HTTP if this is true, so keep it false for local http://localhost dev.
COOKIE_SECURE=false

# ── Cloudinary ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Resend (transactional email) ─────────────────────────
RESEND_API_KEY=""
CONTACT_EMAIL=""
