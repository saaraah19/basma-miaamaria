# URL of the Express API — used server-side (RSC fetch) and client-side.
# Server-side reads NEXT_PUBLIC_API_URL directly; it's exposed to the
# browser deliberately since the API itself enforces auth, not obscurity.
NEXT_PUBLIC_API_URL="http://localhost:5000/api"

# Public site URL — used for canonical tags, sitemap, JSON-LD, OG images.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
